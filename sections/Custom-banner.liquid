{{ 'section-custom-banner.css' | asset_url | stylesheet_tag }}

<!-- Inline responsive styles to dynamically switch between Desktop and Mobile images -->
<style>
  #shopify-section-{{ section.id }} .custom-banner {
    {% if section.settings.desktop_image != blank %}
      background-image: url('{{ section.settings.desktop_image | image_url: width: 1946 }}');
    {% else %}
      background-color: #f7f7f7;
    {% endif %}
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .mobile-graphic-container {
      {% if section.settings.mobile_image != blank %}
        background-image: url('{{ section.settings.mobile_image | image_url: width: 750 }}');
      {% else %}
        background-color: #f0f0f0;
      {% endif %}
    }
  }
</style>

<div class="custom-banner">

  <!-- Header Layout Bar -->
  <header class="banner-header">
    <button type="button" class="mobile-menu-toggle" aria-label="Toggle Menu" aria-expanded="false">
      <span class="icon-hamburger">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 12H21M3 6H21M3 18H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="icon-close" style="display: none;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </span>
    </button>

    <div class="banner-logo">
      <a href="/">{{ section.settings.logo_text }}</a>
    </div>

    <div class="banner-announcement desktop-only">
      <p>{{ section.settings.announcement_text }}</p>
    </div>

    <div class="banner-header-cta desktop-only">
      <a href="{{ section.settings.header_button_link }}" class="btn btn-yellow animated-btn">
        <span>{{ section.settings.header_button_text }}</span>
        <svg class="arrow-icon" width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 1L15 6L10 11M15 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Mobile Menu Drawer Dropdown -->
    <div class="mobile-drawer">
      <div class="mobile-drawer-inner">
        <p class="mobile-announcement">{{ section.settings.announcement_text }}</p>
        <a href="{{ section.settings.header_button_link }}" class="btn btn-yellow animated-btn mobile-cta">
          <span>{{ section.settings.header_button_text }}</span>
          <svg class="arrow-icon" width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 1L15 6L10 11M15 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </header>

  <!-- Main Hero Blocks -->
  <main class="banner-content">
    <!-- Floating Content wrapper block with white background mask -->
    <div class="content-wrapper">
      <h1 class="banner-heading">{{ section.settings.main_heading }}</h1>
      <div class="banner-description">
        <p>{{ section.settings.main_description | newline_to_br }}</p>
      </div>

      <!-- Desktop-Only CTA: hidden on mobile screens -->
      <div class="banner-main-cta desktop-only">
        <a href="{{ section.settings.main_button_link }}" class="btn btn-black animated-btn">
          <span>{{ section.settings.main_button_text }}</span>
          <svg class="arrow-icon" width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 1L15 6L10 11M15 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Mobile-Only Graphic Container (below the text on mobile) -->
    <div class="mobile-graphic-container mobile-only">
      <div class="banner-main-cta">
        <a href="{{ section.settings.main_button_link }}" class="btn btn-black animated-btn">
          <span>{{ section.settings.main_button_text }}</span>
          <svg class="arrow-icon" width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 1L15 6L10 11M15 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </main>

  <!-- Bottom Info Bar -->
  <footer class="banner-footer">
    <p>{{ section.settings.footer_text }}</p>
  </footer>
</div>

{{ 'section-custom-banner.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Full Custom Gift Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Layout Image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "header_button_text",
      "label": "Header Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "header_button_link",
      "label": "Header Button Link"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "main_description",
      "label": "Description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination.\nExplore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "main_button_text",
      "label": "Main Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "main_button_link",
      "label": "Main Button Link"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Marquee/Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Full Custom Gift Banner"
    }
  ]
}
{% endschema %}
