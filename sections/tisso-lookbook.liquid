      "content": "Grid Block 1 Settings Layout"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product Match (Block 1)"
    },
    {
      "type": "range",
      "id": "top_1",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
